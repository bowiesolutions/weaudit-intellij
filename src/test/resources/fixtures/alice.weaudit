      "details": {
        "title": "Unchecked Return Value",
        "severity": "High",
        "difficulty": "Low",
        "type": "Data Validation",
        "description": "The `transfer()` call on line 88 does not check the return value.",
        "exploit": "An attacker can craft a malicious ERC-20 token that returns false from transfer() without reverting, allowing state corruption.",
        "recommendation": "Use `require(token.transfer(...))` or OpenZeppelin's `SafeERC20.safeTransfer`."
      },
      "resolved": false
    },
